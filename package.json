{
	"name": "attack-shark-x11",
	"version": "1.4.2",
	"description": "Desktop configuration app for the Attack Shark X11 gaming mouse.",
	"desktopName": "attack-shark-x11",
	"author": {
		"name": "dressedinblack5",
		"email": "leonvargas4991@gmail.com",
		"url": ""
	},
	"license": "MIT",
	"homepage": "https://github.com/dressedinblack5/attack-shark-x11-electron#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dressedinblack5/attack-shark-x11-electron.git"
	},
	"bugs": {
		"url": "https://github.com/dressedinblack5/attack-shark-x11-electron/issues"
	},
	"keywords": [
		"attack-shark",
		"x11",
		"mouse",
		"driver",
		"linux",
		"usb",
		"hid",
		"typescript"
	],
	"main": "./out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"preview": "electron-vite preview",
		"package": "electron-vite build && electron-builder",
		"lint": "bunx eslint . --ext .ts --cache --cache-strategy content",
		"lint:fix": "bunx eslint . --ext .ts --fix --cache --cache-strategy content",
		"format": "bunx prettier --check . --cache --cache-strategy content",
		"format:fix": "bunx prettier --write . --cache --cache-strategy content",
		"typecheck": "tsc --noEmit",
		"postinstall": "node node_modules/electron/install.js",
		"prepare": "husky",
		"test": "bun test"
	},
	"build": {
		"appId": "com.attackshark.x11",
		"productName": "Attack Shark X11",
		"artifactName": "attack-shark-x11-${version}.${ext}",
		"directories": {
			"output": "dist"
		},
		"files": [
			"out/**/*",
			"package.json"
		],
		"linux": {
			"target": [
				"AppImage",
				"deb"
			],
			"category": "Settings",
			"icon": "assets/attack-shark-x11.svg",
			"syncDesktopName": true
		}
	},
	"lint-staged": {
		"*.{ts,js,json}": [
			"prettier --write",
			"eslint --fix"
		]
	},
	"dependencies": {
		"@electron-toolkit/utils": "^4.0.0",
		"lucide-vue-next": "^1.0.0",
		"usb": "github:dressedinblack5/node-usb-rs",
		"vue": "^3.5.38",
		"vue-i18n": "^11.4.5"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^25.9.3",
		"@vitejs/plugin-vue": "^6.0.7",
		"electron": "^42.4.0",
		"electron-builder": "^26.15.3",
		"electron-vite": "^5.0.0",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"prettier": "3.8.4",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16"
	},
	"trustedDependencies": [
		"usb"
	]
}
